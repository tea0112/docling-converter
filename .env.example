# ─────────────────────────────────────────────────────────────────────────────
# .env — VLM PDF & Image Text Extractor
#
# COPY THIS FILE TO .env AND FILL IN YOUR KEYS:
#   cp .env.example .env
#
# .env is gitignored — only .env.example is tracked.
# ─────────────────────────────────────────────────────────────────────────────

# ── VLM Provider (Pass 1) ──────────────────────────────────────────────────
# VLM_PROVIDER=nvidia  (default) — or openai
#
# NVIDIA NIM
NVIDIA_API_KEY=your_nvidia_key_here
VLM_BASE_URL=https://integrate.api.nvidia.com/v1
VLM_MODEL=meta/llama-3.2-11b-vision-instruct
# VLM_SYSTEM_PROMPT=        # leave empty (default) — /think may reduce diagram extraction quality
# VLM_AUTH_SCHEME=Bearer
#
# OpenAI-compatible (OpenRouter, LM Studio, Ollama, etc.)
# VLM_PROVIDER=openai
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=your_openai_key_here
# OPENAI_MODEL=gpt-4o
# OPENAI_AUTH_SCHEME=Bearer   # or "" depending on your provider

# ── Page selection (PDF only) ───────────────────────────────────────────────
# PAGE_RANGE=1-3  # process only selected pages (1-based, e.g. "1-3" or "1,3,5")

# ── Text Provider (Pass 2 — post-processing, opt-in) ────────────────────────
# Pass 2 is disabled by default. Use --post-process to enable it (VLM-only is the default).
# Pass 1 (VLM): temperature=0.1, top_p=0.9 — accurate extraction
# Pass 2 (text): temperature=0.0 — deterministic verbatim formatting
# If TEXT_API_KEY is not set when --post-process is used, the script warns and falls back to VLM-only.
#
# TEXT_PROVIDER=nvidia  (default) — or openai
#
# NVIDIA NIM (text pass)
TEXT_API_KEY=your_text_api_key_here
TEXT_BASE_URL=https://integrate.api.nvidia.com/v1
TEXT_MODEL=meta/llama-3.1-nemotron-32b-instruct
TEXT_SYSTEM_PROMPT=/think
TEXT_AUTH_SCHEME=Bearer
#
# OpenAI-compatible (text pass)
# TEXT_PROVIDER=openai
# TEXT_BASE_URL=https://api.openai.com/v1
# TEXT_API_KEY=your_text_key_here
# TEXT_MODEL=gpt-4o
# TEXT_AUTH_SCHEME=Bearer   # "Bearer" for endpoints requiring it; "" for OpenAI-compatible
